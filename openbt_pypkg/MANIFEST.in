include LICENSE VERSION
exclude .flake8 .coveragerc
exclude tox.ini
prune src/openbt/bin
prune src/openbt/lib
prune src/openbt/include
include cpp/LICENSE
include cpp/meson.build
include cpp/meson.options
include cpp/includes/*.h
include cpp/src/*.cpp
include cpp/subprojects/*.wrap
exclude cpp/subprojects/README.md
exclude cpp/subprojects/wrapdb.json
